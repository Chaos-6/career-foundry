# Database (required)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/biae

# Anthropic API (required for evaluations)
ANTHROPIC_API_KEY=sk-ant-...

# Security (required - generate a random string)
SECRET_KEY=change-me-in-production

# CORS (default: React dev server)
CORS_ORIGINS=http://localhost:3000

# Rate Limiting (disable for testing)
RATE_LIMIT_ENABLED=true

# Email (optional — leave SMTP_HOST empty for dev mode, emails are logged)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=noreply@biae.app

# App settings
APP_ENV=development
DEBUG=true
